# Tapo Camera Credentials
CAMERA_USER=your_camera_username
CAMERA_PASS=your_camera_password
CAMERA_IP=192.168.1.4
CAMERA_STREAM=stream1

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_CHAT_ID=your_chat_id

# Detection Settings
ALERT_COOLDOWN=30
FRAME_SKIP=3
FACE_TOLERANCE=0.5
MIN_FACE_SIZE=40

# Persistence Tracking — only alert on faces present this long (seconds)
PERSISTENCE_SECONDS=5
GONE_TIMEOUT=8
